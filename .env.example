# === App ===
APP_ENV=local
APP_DEBUG=true

# === Auth (로컬 기본값; 운영은 시크릿 매니저) ===
API_TOKEN=dev-token

# === Postgres ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dip
POSTGRES_PASSWORD=dip
POSTGRES_DB=dip

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dip-neo4j

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === LLM providers (infrastructure 계층에서만 사용) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=1024

# === Jira (읽기 전용 — 값이 모두 있으면 실 어댑터, 없으면 Fake) ===
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
# 콤마로 여러 프로젝트 수집 가능 (예: PA20,ENG) → JQL project IN (...)
JIRA_PROJECT_KEY=
JIRA_MAX_ISSUES=10

# === Git (읽기 전용 로컬 저장소들 — 콤마로 여러 repo. 있으면 실 git log, 없으면 Fake) ===
GIT_REPO_PATHS=/path/to/backend,/path/to/frontend,/path/to/workers
GIT_MAX_COMMITS=2000
