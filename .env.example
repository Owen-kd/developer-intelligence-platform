# === App ===
APP_ENV=local
APP_DEBUG=true

# === Auth (로컬 기본값; 운영은 시크릿 매니저) ===
API_TOKEN=dev-token

# === Postgres ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dip
POSTGRES_PASSWORD=dip
POSTGRES_DB=dip
# 조회 전용 롤(dip_reader, 014 마이그레이션) — 서빙(API/MCP)용. 미설정 시 위 dip 로 폴백.
# 운영 배포 시: `ALTER ROLE dip_reader PASSWORD '<secret>';` 후 아래 주입, API는 이 롤로 접속.
POSTGRES_READER_USER=
POSTGRES_READER_PASSWORD=

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dip-neo4j

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === LLM providers (infrastructure 계층에서만 사용) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=1024

# === Jira (읽기 전용 — 값이 모두 있으면 실 어댑터, 없으면 Fake) ===
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
# 콤마로 여러 프로젝트 수집 가능 (예: PA20,ENG) → JQL project IN (...)
JIRA_PROJECT_KEY=
JIRA_MAX_ISSUES=10

# === Git (읽기 전용 로컬 저장소들 — 콤마로 여러 repo. 있으면 실 git log, 없으면 Fake) ===
GIT_REPO_PATHS=/path/to/backend,/path/to/frontend,/path/to/workers
GIT_MAX_COMMITS=2000

# 위키 생성 비용 제어(오너 결정): 기본 Haiku(저가), 오류/기능개선만 위키화(문의 스킵)
WIKI_MODEL=claude-haiku-4-5
WIKI_DOMAINS=product,order   # 이 도메인만 위키화(facet 기반). stock 등 추가 가능
WIKI_TYPES=오류,기능개선

# Obsidian 볼트 자동 갱신(위키 생성 후 export). 파생 뷰라 비파괴.
OBSIDIAN_AUTO_EXPORT=false
OBSIDIAN_VAULT_PATH=vault
